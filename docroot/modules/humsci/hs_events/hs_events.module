<?php

/**
 * @file
 * hs_events.module
 */

use Drupal\Component\Render\FormattableMarkup;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\StringTranslation\TranslatableMarkup;
use Drupal\hs_entities\HsEntityInterface;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_ENTITY_TYPE_view_alter().
 */
function hs_events_hs_entity_view_alter(array &$build, HsEntityInterface $entity, EntityViewDisplayInterface $display) {
  if ($entity->bundle() != 'event_collections__speaker') {
    return;
  }
  if (!empty($build['field_speaker_person']['#items'])) {
    unset($build['label']);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function hs_events_form_node_hs_event_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Add the auto-unpublish field with default value to the advanced options
  // to organize this field with other publishing options in the sidebar.
  $form_modifier = \Drupal::service('hs_events.event_form_modifier');
  $form_modifier->moveAutoUnpublishFieldToOptions($form);
  $form_modifier->setAutoUnpublishDefaultValue($form);
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function hs_events_form_node_hs_event_edit_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Add the auto-unpublish field to the advanced options to organize this field
  // with other publishing options in the sidebar.
  $form_modifier = \Drupal::service('hs_events.event_form_modifier');
  $form_modifier->moveAutoUnpublishFieldToOptions($form);
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function hs_events_form_config_pages_hs_site_options_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (!isset($form['field_site_auto_unpublish'])) {
    return;
  }

  $form['field_site_auto_unpublish']['widget']['#description'] = t("By default, should new events auto-unpublish once they've past?");
  $form['field_site_auto_unpublish']['widget']['#description'] .= '<br/><br/>';
  $form['field_site_auto_unpublish']['widget']['#description'] .= _hs_events_auto_unpublish_existing_events_message();

  // Add validation handler to check for auto-unpublish field changes.
  $form['#validate'][] = 'hs_events_site_options_form_validate';

  // Store original values for comparison on validation.
  if (!$form_state->has('original_values')) {
    $original_values = [];
    if (isset($form['field_site_auto_unpublish']['widget']["#default_value"][0])) {
      $original_values['field_site_auto_unpublish'] = $form['field_site_auto_unpublish']['widget']["#default_value"][0];
    }
    $form_state->set('original_values', $original_values);
  }
}

/**
 * Validation handler for the site options form.
 *
 * Checks if the auto-unpublish field value has changed and displays a warning
 * message to inform users that changing the default setting does not affect
 * existing events.
 *
 * @param array $form
 *   The form array.
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 *   The form state object.
 */
function hs_events_site_options_form_validate($form, FormStateInterface $form_state) {
  // Check if the auto-unpublish field value has changed.
  $original_value = $form_state->get('original_values')['field_site_auto_unpublish'] ?? NULL;
  $new_value = $form_state->getValue(['field_site_auto_unpublish', 0, 'value']);

  if ($original_value !== $new_value) {
    \Drupal::messenger()->addWarning(_hs_events_auto_unpublish_existing_events_message());
  }
}

/**
 * A help message about how to change existing events.
 *
 * @return \Drupal\Component\Render\FormattableMarkup|\Drupal\Core\StringTranslation\TranslatableMarkup
 */
function _hs_events_auto_unpublish_existing_events_message(): FormattableMarkup|TranslatableMarkup {
  return t('Changing the default for "Auto-unpublish events once past" does not impact existing events. Visit <a href=":url" target="_blank">the list of all events</a>, select the events that you want to change, and use the %action bulk action to set the %field_name field to %on or %off.', [
    ':url' => '/admin/content/manage/event',
    '%action' => t('Modify field values'),
    '%field_name' => t('Auto-unpublish when event is past'),
    '%on' => t('On'),
    '%off' => t('Off'),
  ]);
}

/**
 * Implements hook_cron().
 */
function hs_events_cron() {
  // Use the auto-unpublish service to identify past events that are slated to
  // be auto-unpublished and then unpublish them.
  $auto_unpublish_service = \Drupal::service('hs_events.auto_unpublish_events');
  $auto_unpublish_service->unpublishPastEvents();
}

/**
 * Implements hook_views_query_alter().
 */
function hs_events_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
  // Restrict the Duplicate Events admin view to events that share both their
  // title and start date with at least one other published event.
  if ($view->id() !== 'hs_default_duplicate_events') {
    return;
  }

  // Build a correlated subquery returning nids whose (title, start_date)
  // appears more than once among published hs_event nodes.
  $outer = \Drupal::database()->select('node_field_data', 'd_nfd');
  $outer->innerJoin(
    'node__field_hs_event_date',
    'd_date',
    'd_date.entity_id = d_nfd.nid AND d_date.deleted = 0'
  );
  $outer->addField('d_nfd', 'nid');
  $outer->where(
    "(d_nfd.title, d_date.field_hs_event_date_value) IN (
       SELECT sub_nfd.title, sub_date.field_hs_event_date_value
       FROM {node_field_data} sub_nfd
       INNER JOIN {node__field_hs_event_date} sub_date
         ON sub_date.entity_id = sub_nfd.nid AND sub_date.deleted = 0
       WHERE sub_nfd.type = :type AND sub_nfd.status = 1
       GROUP BY sub_nfd.title, sub_date.field_hs_event_date_value
       HAVING COUNT(sub_nfd.nid) > 1
     )",
    [':type' => 'hs_event']
  );

  /** @var \Drupal\views\Plugin\views\query\Sql $query */
  $query->addWhereExpression(
    '0',
    'node_field_data.nid IN (' . $outer . ')',
    $outer->getArguments()
  );
}
