<?php

/**
 * @file
 * hs_layouts.module
 */

use Drupal\Component\Utility\Html;
use Drupal\dashboard\Plugin\SectionStorage\DashboardSectionStorage;
use Drupal\paragraphs\ParagraphInterface;

/**
 * Implements hook_plugin_filter_TYPE__CONSUMER_alter().
 */
function hs_layouts_plugin_filter_layout__layout_builder_alter(&$definitions, &$extra, &$consumer) {
  /** @var \Drupal\Core\Layout\LayoutDefinition $definition */
  foreach ($definitions as $id => $definition) {
    $provider = $definition->getProvider();
    if ($extra['section_storage'] instanceof DashboardSectionStorage) {
      // Define providers to unset for the dashboard.
      $providers_to_unset = [
        'ui_patterns_library',
        'hs_layouts',
        'ds',
      ];
      if (in_array($provider, $providers_to_unset)) {
        unset($definitions[$id]);
      }
    }
    else {
      if ($provider !== 'hs_layouts') {
        unset($definitions[$id]);
      }
    }
  }
}

/**
 * Implements hook_plugin_filter_TYPE__CONSUMER_alter().
 */
function hs_layouts_plugin_filter_block__layout_builder_alter(&$definitions, &$extra) {
  foreach ($definitions as $id => &$definition) {
    if (strpos($id, 'views_exposed_filter_block') !== FALSE) {
      $view_block = str_replace('views_exposed_filter_block:', 'views_block:', $id);
      if (isset($definitions[$view_block])) {
        $definition['category'] = $definitions[$view_block]['category'];
        $definition['admin_label'] = t('@view: @display <span class="view-form">Exposed form</span>', $definitions[$view_block]['admin_label']->getArguments());
      }
    }
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function hs_layouts_preprocess_page(&$variables) {
  // Load layout-builder-vertical-tabs lib in the layout builder override form.
  if (\Drupal::routeMatch()->getRouteName() == 'layout_builder.overrides.node.view') {
    $variables['#attached']['library'][] = 'hs_layouts/layout-builder-vertical-tabs';
  }
}

/**
 * Implements hook_preprocess().
 */
function hs_layouts_preprocess(&$variables, $hook) {
  // List of patterns used for collection children elements.
  $collection_patterns = [
    'pattern_horizontal_card',
    'pattern_vertical_card',
    'pattern_vertical_link_card',
    'pattern_vertical_button_card',
    'pattern_spotlight',
    'pattern_timeline',
    'pattern_hero_text_overlay',
    'pattern_gradient_hero',
  ];
  if (!in_array($hook, $collection_patterns)) {
    return;
  }
  // Set heading tag to h2 by default.
  $variables['heading_tag'] = 'h2';
  // Continue only if the pattern is a layout.
  $context = $variables['context'];
  if (!$context->isOfType('layout')) {
    return;
  }
  $paragraph = $context->getProperty('entity');
  if (!$paragraph instanceof ParagraphInterface) {
    return;
  }

  // Get the parent entity of the paragraph.
  $parent = $paragraph->getParentEntity();
  if ($hook === 'pattern_gradient-hero' && $parent instanceof ParagraphInterface) {
    // Gradient hero elements can be within a slider,
    // need to go a level depeer.
    $parent = $parent->getParentEntity();
  }
  if (!($parent instanceof ParagraphInterface) || !in_array($parent->bundle(), ['hs_collection', 'hs_priv_collection'])) {
    return;
  }
  if ($parent->get('field_title_settings')->value !== 'collection_title_none') {
    // If the paragraph is within a collection and the collection title is
    // set to anything other than 'None', set the heading tag to h3.
    $variables['heading_tag'] = 'h3';
  }

  // Switch image style for vertical cards depending on collection column count.
  if (!in_array($hook, [
    'pattern_vertical_card',
    'pattern_vertical_link_card',
    'pattern_vertical_button_card',
  ])) {
    return;
  }
  if ($parent->hasField('field_hs_collection_per_row') && !$parent->get('field_hs_collection_per_row')->isEmpty()) {
    $col_count = (int) $parent->get('field_hs_collection_per_row')->value;

    // Decide which responsive image style to use.
    $style = NULL;
    switch ($col_count) {
      case 2:
        $style = 'postcard_vertical_2_across';
        break;

      case 3:
      case 4:
        $style = 'postcard_vertical_3_across';
        break;
    }

    if ($style && isset($variables['image']['field_hs_postcard_image'][0])) {
      // Change image style based on column count.
      $variables['image']['field_hs_postcard_image'][0]['#stanford_media_image_style'] = $style;
      // Add extra cache key to prevent using a cached version with a different
      // image style.
      $variables['image']['field_hs_postcard_image'][0]['#cache']['keys'][] = 'image_style:' . $style;
    }
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function hs_layouts_preprocess_container(&$variables) {
  if (!empty($variables['element']['layout-section'])) {
    // Add styles to the layout builder admin configuration.
    $variables['#attached']['library'][] = 'hs_layouts/layout_builder_admin';
  }
}

/**
 * Implements hook_preprocess_preprocess_pattern_spotlight().
 */
function hs_layouts_preprocess_pattern_spotlight(&$variables) {
  $context = $variables['context'];
  $paragraph = $context->getProperty('entity');

  if ($context->isOfType('views_row')) {
    $variables['attributes']->addClass('hb-spotlight--framed');
  }

  if (!($paragraph instanceof ParagraphInterface)) {
    return;
  }

  if (
    $paragraph->hasField('field_hs_spotlight_background') &&
    $paragraph->get('field_hs_spotlight_background')->count()
  ) {
    $bgValue = $paragraph->get('field_hs_spotlight_background')->getString();
    $variables['attributes']->addClass(Html::cleanCssIdentifier($bgValue));
  }

  $spotlight_type = 'framed';
  if (
    $paragraph->hasField('field_hs_spotlight_style') &&
    !$paragraph->get('field_hs_spotlight_style')->isEmpty()
  ) {
    $spotlight_type = $paragraph->get('field_hs_spotlight_style')->value;
  }

  $image_height = 'tall';
  if (
    $paragraph->hasField('field_hs_spotlight_image_height') &&
    !$paragraph->get('field_hs_spotlight_image_height')->isEmpty()
  ) {
    $image_height = $paragraph->get('field_hs_spotlight_image_height')->value;
  }
  $variables['attributes']->addClass('hb-spotlight--view-mode-' . $image_height);

  if ($paragraph->hasField('field_hs_spotlight_image')) {
    if ($paragraph->get('field_hs_spotlight_image')->isEmpty() || !$paragraph->get('field_hs_spotlight_image')->entity) {
      $variables['attributes']->addClass('hb-spotlight--no-media');
    }
    else {
      $media = $paragraph->get('field_hs_spotlight_image')->entity;
      if ($media->bundle() === 'video') {
        $spotlight_type = 'video';
      }
      elseif ($media->bundle() === 'image' && $spotlight_type === 'framed') {
        $image_style = $image_height == 'tall' ? 'spotlight_framed_tall' : 'spotlight_framed_short';
        $variables['image']['field_hs_spotlight_image'][0]['#stanford_media_image_style'] = $image_style;
        $variables['image']['field_hs_spotlight_image'][0]['#cache']['keys'][] = 'image_style:' . $image_style;
      }
    }
  }
  $variables['attributes']->addClass(Html::cleanCssIdentifier('hb-spotlight--' . $spotlight_type));
}

/**
 * Implements hook_preprocess_preprocess_pattern_accordion().
 */
function hs_layouts_preprocess_pattern_accordion(&$variables) {
  $paragraph = $variables['context']->getProperty('entity');
  if (!($paragraph instanceof ParagraphInterface)) {
    return;
  }

  if (
    $paragraph->hasField('field_hs_accord_expcol') &&
    !$paragraph->get('field_hs_accord_expcol')->isEmpty() &&
    $paragraph->get('field_hs_accord_expcol')->getString()
  ) {
    $variables['attributes']->addClass('hb-accordion_toggle-all');
  }

  if (
    $paragraph->hasField('field_hs_accordion_style')
  ) {
    switch ($paragraph->get('field_hs_accordion_style')->getString()) {
      case 'secondary':
        $variables['attributes']->addClass('hb-accordion-secondary');
        break;

      case 'light':
        $variables['attributes']->addClass('hb-accordion-light');
        break;
    }
  }

  // Set a fallback value just in case something happens to the field
  // since this is being output directly as the html element.
  $variables['heading_level'] = 'div';
  if (
    $paragraph->hasField('field_summary_heading_level') &&
    !$paragraph->get('field_summary_heading_level')->isEmpty()
  ) {
    $variables['heading_level'] = $paragraph->get('field_summary_heading_level')->getString();
  }
}

/**
 * Helper function to make the title of the card the link.
 */
function _hs_layouts_make_title_the_link(&$variables) {
  $renderer = \Drupal::service('renderer');
  if (!empty($variables['button'])) {
    $dom = new DOMDocument();
    try {
      $button = is_array($variables['button']) ? $variables['button'] : (string) $variables['button'];
      if (!empty($button['field_hs_postcard_link'][0]['#url']) && $button['field_hs_postcard_link'][0]['#url']->isRouted()) {
        $variables['href'] = $button['field_hs_postcard_link'][0]['#url']->toString();
        if (!empty($button['field_hs_postcard_link'][0]['#title'])) {
          $variables['link_text'] = (string) $button['field_hs_postcard_link'][0]['#title'];
        }
      }
      else {
        $dom->loadHTML($renderer->renderInIsolation($button));
      }
    }
    catch (\Throwable $e) {
      return;
    }
    $xpath = new DOMXPath($dom);
    $anchors = $xpath->query('//a');
    // If the markup is a link, grab its href and its visible text.
    $anchor = $anchors->item(0);
    if ($anchor instanceof DOMElement) {
      $variables['href'] = $anchor->getAttribute('href');
      $variables['link_text'] = trim($anchor->textContent);
    }
    else {
      $variables['href'] = $variables['href'] ?? htmlspecialchars_decode(trim(strip_tags($renderer->renderInIsolation($variables['button']))));
    }

    $variables['link_url'] = $variables['href'];
  }

  if (!empty($variables['title'])) {
    $title = is_array($variables['title']) ? $renderer->renderInIsolation($variables['title']) : (string) $variables['title'];
    $title_markup = trim(strip_tags($title));
    $variables['title'] = $title_markup !== '' ? ['#markup' => $title_markup] : NULL;
  }
}

/**
 * Resolves the card link for both layout and Views contexts.
 */
function _hs_layouts_set_card_link(&$variables) {
  $context = $variables['context'];
  if ($context->isOfType('layout')) {
    // Paragraphs: build the link from the button and link the title.
    _hs_layouts_make_title_the_link($variables);
    return;
  }

  // Views: the title may already be linked.
  $renderer = \Drupal::service('renderer');
  $title_rendered = is_array($variables['title'])
    ? $renderer->renderInIsolation($variables['title'])
    : $variables['title'];

  if (is_null($title_rendered) || strpos($title_rendered, '<a') === FALSE) {
    $original_title = $variables['title'];
    // Title isn't linked: get the link from the button.
    _hs_layouts_make_title_the_link($variables);
    // Restore original title, because it was overridden above.
    $variables['title'] = $original_title;
  }
  elseif (preg_match('/href="([^"]+)"/', $title_rendered, $matches)) {
    // Title already linked: reuse its href for the data attribute only —
    // don't set href, or Twig re-wraps the title and nests anchors.
    $variables['link_url'] = html_entity_decode($matches[1]);
    $variables['link_text'] = $title_rendered;
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function hs_layouts_preprocess_pattern_vertical_link_card(&$variables) {
  _hs_layouts_make_title_the_link($variables);
}

/**
 * Implements hook_preprocess_HOOK().
 */
function hs_layouts_preprocess_pattern_vertical_card(&$variables) {
  _hs_layouts_set_card_link($variables);
}

/**
 * Implements hook_preprocess_HOOK().
 */
function hs_layouts_preprocess_pattern_date_stacked_vertical_card(&$variables) {
  _hs_layouts_set_card_link($variables);
}

/**
 * Implements hook_preprocess_HOOK().
 */
function hs_layouts_preprocess_pattern_horizontal_card(&$variables) {
  $context = $variables['context'];
  if ($context->isOfType('layout')) {
    // Functionality for paragraphs.
    _hs_layouts_make_title_the_link($variables);
  }
}
