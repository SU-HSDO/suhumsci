{% if variant == 'open' %}
  {% set attributes = attributes.setAttribute('open', 'open') %}
{% endif %}

<details{{ attributes }}>
  {%- if title -%}
    <summary{{ summary_attributes.addClass(summary_classes) }}>
      <{{ heading_level}} class="field-hs-accordion-summary">
        {{ title }}
      </{{ heading_level}}>
    </summary>
  {%- endif -%}
  <div class="revealed-details">
    {# Wrapper enables the grid height animation (see _pattern.accordion.scss). #}
    <div class="revealed-details__inner">
      {{ description }}

      {%- if children -%}
        <div class="children">
          {{ children }}
        </div>
      {%- endif -%}

      {{ value }}
    </div>
  </div>
</details>
