/**
 * Migrate Collections paragraph data from old fields to new fields.
 */
function hs_paragraph_types_update_10028(&$sandbox) {
  $paragraph_storage = \Drupal::entityTypeManager()->getStorage('paragraph');

  if (empty($sandbox['ids'])) {
    // Get list of collection paragraphs.
    $sandbox['ids'] = $paragraph_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('type', ['hs_collection', 'hs_priv_collection'], 'IN')
      ->execute();
    $sandbox['total'] = count($sandbox['ids']);
    $sandbox['updated'] = 0;

  }

  // Map old width machine names (underscores) to new ones (hyphens).
  $width_map = [
    'limited_width' => 'limited-width',
    'full_width'    => 'full-width',
  ];

  $paragraph_ids = array_splice($sandbox['ids'], 0, 50);

  foreach ($paragraph_storage->loadMultiple($paragraph_ids) as $paragraph) {
    /** @var \Drupal\paragraphs\Entity\Paragraph $paragraph */

    $save_needed = FALSE;

    // Migrate field_bg_color -> field_hs_collection_background.
    // Empty/null values become "bg-none" in the new field.
    if ($paragraph->hasField('field_bg_color') && $paragraph->hasField('field_hs_collection_background')) {
      $value = $paragraph->get('field_bg_color')->value;
      $background = empty($value) ? 'bg-none' : $value;
      $paragraph->set('field_hs_collection_background', $background);
      $save_needed = TRUE;
    }

    // Migrate field_bg_color_width -> field_hs_collection_bg_width.
    // Only migrate if a value exists and a mapping is defined.
    if ($paragraph->hasField('field_bg_color_width') && $paragraph->hasField('field_hs_collection_bg_width')) {
      $value = $paragraph->get('field_bg_color_width')->value;
      if (!empty($value) && isset($width_map[$value])) {
        $paragraph->set('field_hs_collection_bg_width', $width_map[$value]);
        $save_needed = TRUE;
      }
    }

    if ($save_needed) {
      $paragraph->save();
      $sandbox['updated']++;
    }
  }

  $sandbox['#finished'] = count($sandbox['ids']) ? 1 - count($sandbox['ids']) / $sandbox['total'] : 1;

  if ($sandbox['#finished'] === 1) {
    if ($sandbox['updated'] !== $sandbox['total']) {
      \Drupal::logger('hs_paragraph_types')->error('Error: failed updating %count hs_collections and hs_priv_collections paragraphs.', [
        '%count' => $sandbox['total'] - $sandbox['updated'],
      ]);
    }

    return t('Updated %updated of %total hs_collections and hs_priv_collections paragraphs.', [
      '%updated' => $sandbox['updated'],
      '%total' => $sandbox['total'],
    ]);
  }
}

