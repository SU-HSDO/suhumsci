/**
 * Add field_auto_unpublish field to bottom of the event form display.
 */
function su_humsci_profile_update_9742() {
  $config_storage = \Drupal::service('config.storage.sync');

  /** @var \Drupal\field\FieldConfigInterface $field_config_storage */
  $field_config_storage = \Drupal::service('entity_type.manager')->getStorage('field_config');

  /** @var \Drupal\field\FieldConfigInterface $field_storage */
  $field_storage = \Drupal::service('entity_type.manager')->getStorage('field_storage_config');

  // Create field_storage if it does not exist.
  $auto_unpublish_field_storage = $config_storage->read('field.storage.node.field_auto_unpublish');
  if (
    empty($field_storage->load('node.field_auto_unpublish')) &&
    !empty($auto_unpublish_field_storage)
  ) {
    $field_storage->createFromStorageRecord($auto_unpublish_field_storage)->save();
  }

  // Create field_config if it does not exist.
  $auto_unpublish_field_config = $config_storage->read('field.field.node.hs_event.field_auto_unpublish');
  if (
    empty($field_config_storage->load('node.hs_event.field_auto_unpublish')) &&
    !empty($auto_unpublish_field_config)
  ) {
    $field_config_storage->create($auto_unpublish_field_config)->save();
  }

  $entity_type_manager = \Drupal::entityTypeManager();

  // Add the field to the form display for the event content type.
  $form_display = $entity_type_manager->getStorage('entity_form_display')
    ->load('node.hs_event.default');
  if ($form_display) {
    $weight = max(array_column($form_display->getComponents(), 'weight') ?: [0]);
    $form_display->setComponent('field_auto_unpublish', [
      'type' => 'boolean_checkbox',
      'settings' => [
        'display_label' => TRUE,
      ],
      'weight' => $weight + 1,
    ])->save();
  }
}

/**
 * Update VBO Views to hide show_select_all behavior by default.
 */
function su_humsci_profile_update_9743(&$sandbox) {
  $views_storage = \Drupal::service('entity_type.manager')
    ->getStorage('view');

  if (!isset($sandbox['current'])) {
    $sandbox['total'] = $views_storage
      ->getQuery()
      ->accessCheck(FALSE)
      ->count()
      ->execute();
    $sandbox['current'] = 0;
    $sandbox['changed'] = 0;
    $sandbox['skipped'] = 0;
    $sandbox['errors'] = 0;
  }

  $query = $views_storage
    ->getQuery()
    ->accessCheck(FALSE);

  $query->range($sandbox['current'], 10);
  $results = $query->execute();
  if (!empty($results)) {
    foreach ($results as $view_id) {
      $view = $views_storage->load($view_id);
      $displays = $view->get('display');
      $changed = FALSE;
      $skipped = FALSE;
      foreach ($displays as $display_id => &$display) {
        if (!empty($display['display_options']['fields'])) {
          foreach ($display['display_options']['fields'] as &$field) {
            if (isset($field['plugin_id']) && $field['plugin_id'] === 'views_bulk_operations_bulk_form') {
              if (!isset($field['clear_on_exposed']) || $field['clear_on_exposed'] !== TRUE) {
                $field['clear_on_exposed'] = TRUE;
                $changed = TRUE;
              }
              else {
                $skipped = TRUE;
                \Drupal::logger('su_humsci_profile')->warning('VBO field clear_on_exposed not set in view @view display @display.', [
                  '@view' => $view_id,
                  '@display' => $display_id,
                ]);
              }
              if (!isset($field['show_select_all']) || $field['show_select_all'] !== 'always_hide') {
                $field['show_select_all'] = 'always_hide';
                $changed = TRUE;
              }
              else {
                $skipped = TRUE;
                \Drupal::logger('su_humsci_profile')->warning('VBO field show_select_all not set in view @view display @display.', [
                  '@view' => $view_id,
                  '@display' => $display_id,
                ]);
              }
              if ($changed) {
                $sandbox['changed']++;
              }
              if ($skipped) {
                $sandbox['skipped']++;
              }
            }
          }
        }
      }

      if ($changed) {
        $view->set('display', $displays);
        try {
          $view->save();
        }
        catch (\Exception $e) {
          $sandbox['errors']++;
          \Drupal::logger('su_humsci_profile')->error('Failed to save view @view: @error', [
            '@view' => $view_id,
            '@error' => $e->getMessage(),
          ]);
        }
      }
      $sandbox['current']++;
      $sandbox['#finished'] = $sandbox['current'] / $sandbox['total'];
    }
  }

  if ($sandbox['#finished'] >= 1) {
    if ($sandbox['changed']) {
      \Drupal::logger('su_humsci_profile')->notice('VBO field update: @updated fields updated, @skipped fields skipped, @errors save errors.', [
        '@updated' => $sandbox['changed'],
        '@skipped' => $sandbox['skipped'],
        '@errors' => $sandbox['errors'],
      ]);
    }
    else {
      \Drupal::logger('su_humsci_profile')->notice('VBO field update: No VBO view displays were changed.');
    }
  }
}

