{
  "name": "humsci_basic",
  "version": "1.0.0",
  "description": "Humsci Basic",
  "type": "module",
  "scripts": {
    "start": "npm run build && npm run watch",
    "backstop:init": "node ./backstop/generate-backstop.js",
    "backstop:reference": "backstop reference --config='./backstop/backstop.json'",
    "backstop:test": "backstop test --config='./backstop/backstop.json'",
    "build": "webpack --config webpack.prod.js",
    "lint:sass": "stylelint 'src/scss/**/*.scss'",
    "test:sass": "mocha 'tests/true-sass-spec.js'",
    "lint:js": "eslint 'src/**/*.js'",
    "lint:js:fix": "eslint 'src/**/*.js' --fix",
    "watch": "webpack --watch --config webpack.dev.js",
    "lint": "npm run lint:sass && npm run lint:js",
    "test": "npm run lint:sass && npm run test:sass",
    "visreg:colorful": "percy snapshot tests/percy/.snapshots-colorful.js",
    "visreg:traditional": "percy snapshot tests/percy/.snapshots-traditional.js",
    "visreg": "percy snapshot tests/percy/.snapshots-all.js"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^8.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@percy/cli": "^1.28.5",
    "autoprefixer": "^9.8.8",
    "babel-loader": "^9.1.2",
    "backstopjs": "^6.3.23",
    "browserslist": "^4.25.4",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-webpack-plugin": "^3.2.0",
    "mini-css-extract-plugin": "^2.9.4",
    "mocha": "^10.2.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.6.2",
    "sass": "^1.58.0",
    "sass-loader": "^16.0.5",
    "sass-true": "^7.0.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-merge": "^6.0.1",
    "webpack-remove-empty-scripts": "^1.1.1"
  }
}
